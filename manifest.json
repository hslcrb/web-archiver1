{
  "manifest_version": 3,
  "name": "Web Archiver Pro",
  "version": "1.0.0",
  "description": "완벽한 웹 브라우징 아카이빙 도구 (WACZ & ZIP 내보내기)",
  "permissions": [
    "debugger",
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "downloads",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "pages/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pages/floating.html", 
        "pages/floating.js",
        "pages/index.html", 
        "pages/player.html",
        "libs/jszip.min.js", 
        "engines/wacz_engine.js", 
        "engines/conversion_engine.js", 
        "engines/db.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
